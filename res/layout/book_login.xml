<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:id="@id/rootViewGroup" android:padding="5.0dip" android:layout_width="fill_parent" android:layout_height="fill_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView android:textSize="18.0sp" android:id="@id/txt_login_username" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="用户名：" android:layout_alignParentTop="true" />
