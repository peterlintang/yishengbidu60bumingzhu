    <item android:id="@android:id/background">
        <shape>
            <gradient android:startColor="#ffbebebe" android:endColor="#ffbebebe" android:angle="270.0" android:centerY="0.75" android:centerColor="#ffbebebe" />
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <gradient android:startColor="#ff1c82ac" android:endColor="#ff1c82ac" android:angle="270.0" android:centerY="0.75" android:centerColor="#ff1c82ac" />
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient android:startColor="#ff1c82ac" android:endColor="#ff1c82ac" android:angle="270.0" android:centerY="0.75" android:centerColor="#ff1c82ac" />
            </shape>
        </clip>
    </item>
</layer-list>
